\ProvidesPackage{letter}

\geometry{
  xetex,paper=letterpaper,centering,twoside,includehead,includefoot,nomarginpar,
  bindingoffset=0mm,
  inner=15mm,outer=25mm,top=5mm,bottom=10mm,
  headheight=5.2mm,headsep=5mm,footskip=7mm,
  showframe=true,showcrop=true,
  }
\renewcommand{\baselinestretch}{1.5}
\setlength{\parskip}{1em}
\setlength{\parindent}{2em}%
\pagenumbering{gobble}
\renewcommand{\headrulewidth}{0pt}
